# Supabase — get these from your project dashboard (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to client

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # change to your production URL when deploying
